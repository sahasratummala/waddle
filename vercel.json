{
  "buildCommand": "npm run build --workspace=client && npm run build --workspace=server",
  "outputDirectory": "client/dist",
  "installCommand": "npm install"
}
{
  "build": {
    "buildCommand": "npm install && npm run build --workspace=server"
  },
  "deploy": {
    "startCommand": "cd server && node dist/index.js"
  }
}
